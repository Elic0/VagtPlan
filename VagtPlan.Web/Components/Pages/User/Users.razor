@page "/users"
@rendermode InteractiveServer
@inject UserApiClient UserApi
@inject DepartmentApiClient DepartmentApi
@inject UserRoleApiClient UserRoleApi
@inject NavigationManager Navigation
@using VagtPlan.Web.Models
@using System.Linq

<div class="users-page">
    <header class="page-header">
        <div>
            <p class="page-eyebrow">Vagtplan</p>
            <h1>Bruger håndtering</h1>
            <p class="page-subtitle">Opret brugere og administrer eksisterende brugere.</p>
        </div>
    </header>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert-banner" role="alert">@_error</div>
    }

    <section class="card-panel create-panel">
        <h2>Opret bruger</h2>

        <EditForm Model="_newUser" OnValidSubmit="CreateUserAsync" FormName="create-user" class="create-form">
            <DataAnnotationsValidator />
            <div class="form-row">
                <div class="field-group">
                    <label for="user-name">Navn</label>
                    <InputText id="user-name" @bind-Value="_newUser.Name" class="field-input" placeholder="Bruger navn" />
                </div>
                <div class="field-group">
                    <label for="user-department">Afdeling</label>
                    <InputSelect id="user-department" TValue="int" @bind-Value="_newUser.DepartmentId" class="field-input">
                        <option value="0" disabled>Vælg afdeling</option>
                        @foreach (var d in _departments)
                        {
                            <option value="@d.Id">@d.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="field-group">
                    <label for="user-role">Rolle</label>
                    <InputSelect id="user-role" TValue="int" @bind-Value="_newUser.UserRoleId" class="field-input">
                        <option value="0" disabled>Vælg rolle</option>
                        @foreach (var r in _userRoles)
                        {
                            <option value="@r.Id">@r.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="field-group">
                    <label for="user-vacation">Vaction Dage</label>
                    <InputNumber id="user-vacation" @bind-Value="_newUser.VactionDays" class="field-input" placeholder="Vaction Dage" />
                </div>
                <button type="submit" class="btn-primary-action" disabled="@_isSaving">
                    @(_isSaving ? "Opretter…" : "Opret bruger")
                </button>
            </div>
        </EditForm>
    </section>

    <section class="card-panel list-panel">
        <div class="panel-heading">
            <h2>Alle brugere</h2>
            <span class="count-badge">@_users.Length</span>
        </div>
    </section>

    <section class="user-list">
        @if (_isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <span>Henter brugere...</span>
            </div>
        }
        else if (_users.Length == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">◎</div>
                <p>Ingen brugere</p>
            </div>

        }
        else
        {
            <div class="user-grid">
                @foreach (var user in _users)
                {
                    <article class="user-card">
                        <div class="user-card-body">
                            <h3>@user.Name</h3>
                            <p>Afdeling: @GetDepartmentName(user.DepartmentId)</p>
                            <p>Rolle: @GetUserRoleName(user.UserRoleId)</p>
                            <p>Vaction dage: @user.VactionDays</p>
                        </div>
                        <div class="user-card-actions">
                            <button class="btn-edit" @onclick="() => NavigateToEdit(user.Id)">Rediger bruger</button>
                            <button class="btn-delete" @onclick="() => DeleteUserAsync(user.Id)">Slet</button>
                        </div>
                    </article>
                }
            </div>
        }

    </section>

</div>

@code {
    private UserModel[] _users = Array.Empty<UserModel>();
    private DepartmentModel[] _departments = Array.Empty<DepartmentModel>();
    private UserRoleModel[] _userRoles = Array.Empty<UserRoleModel>();
    private UserDto _newUser = new UserDto {
        Name = string.Empty,
        VactionDays = 0,
        DepartmentId = 0,
        UserRoleId = 0,
        password = null
    };
    private bool _isLoading = true;
    private bool _isSaving = false;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
            await LoadDepartmentsAsync();
            await LoadUserRolesAsync();
            await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            _isLoading = true;
            _users = await UserApi.GetAllAsync();
        }
        catch (InvalidOperationException ex) when (ex.Message.Contains("ikke logget ind", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            _error = $"Fejl ved indlæsning af brugere: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadDepartmentsAsync()
    {
        try
        {
            _departments = await DepartmentApi.GetAllAsync();
        }
        catch (Exception)
        {
            // non-fatal: keep departments empty and show generic error
            _error ??= "Kunne ikke hente afdelinger.";
        }
    }

    private async Task LoadUserRolesAsync()
    {
        try
        {
            _userRoles = await UserRoleApi.GetAllAsync();
        }
        catch (Exception)
        {
            _error ??= "Kunne ikke hente roller.";
        }
    }

    private string GetDepartmentName(long id)
    {
        if (id == 0) return "-";
        var d = _departments.FirstOrDefault(x => x.Id == id);
        return d?.Name ?? id.ToString();
    }

    private string GetUserRoleName(long id)
    {
        if (id == 0) return "-";
        var r = _userRoles.FirstOrDefault(x => x.Id == id);
        return r?.Name ?? id.ToString();
    }

    private async Task CreateUserAsync()
    {
        try
        {
            _isSaving = true;
            var createdUser = await UserApi.CreateAsync(_newUser);
            if (createdUser != null)
            {
                Navigation.NavigateTo($"/users/{createdUser.Id}");
            }
        }
        catch (Exception ex)
        {
            _error = $"Fejl ved oprettelse af bruger: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void NavigateToEdit(int userId)
    {
        Navigation.NavigateTo($"/users/{userId}");
    }

    private async Task DeleteUserAsync(int userId)
    {
        _isSaving = true;
        _error = null;

        try
        {
            await UserApi.DeleteAsync(userId);
            await LoadUsersAsync();
        }
        catch (Exception)
        {
            _error = "Kunne ikke slette bruger.";
        }
        finally
        {
            _isSaving = false;
        }
    }
}
