@page "/schedule"
@rendermode InteractiveServer
@using VagtPlan.Web.Services
@using System.Globalization
@inject WorkDayService WorkDayService
@inject UserService UserService
@inject StatusService StatusService
@inject NavigationManager Navigation
@inject ApiAuthState AuthState

<PageTitle>Vagtplan — VagtPlan</PageTitle>

<div class="departments-page page-wide">
    <header class="page-header">
        <div>
            <p class="page-eyebrow">Vagtplan</p>
            <h1>Vagtplan</h1>
            <p class="page-subtitle">Overblik over arbejdsdage, statusser og tildelinger.</p>
        </div>
    </header>
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert-banner" role="alert">@errorMessage</div>
    }

<section class="card-panel">
    <div class="schedule-toolbar">
        <div class="schedule-month-nav">
            <button class="btn btn-outline-secondary" @onclick="PrevMonth" aria-label="Forrige måned">&lt;</button>
            <strong>@DisplayedMonth.ToString("MMMM yyyy", DanishCulture)</strong>
            <button class="btn btn-outline-secondary" @onclick="NextMonth" aria-label="Næste måned">&gt;</button>
        </div>
        <div class="schedule-filter">
            <label class="form-check-label">Vis kun brugere med tildelinger</label>
            <input type="checkbox" class="form-check-input" @bind="showOnlyWithAssignments" />
        </div>
    </div>
</section>

@if (users == null || statuses == null || workdays == null)
{
    <section class="card-panel">
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Indlæser vagtplan…</span>
        </div>
    </section>
}
else
{
    <section class="card-panel list-panel">
        <div class="panel-heading">
            <h2>Månedsoversigt</h2>
            <span class="count-badge">@FilteredUsers.Count()</span>
        </div>
        @if (!FilteredUsers.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-calendar3"></i></div>
                <p>Ingen brugere at vise</p>
                <span>Prøv at slå filteret fra eller vælg en anden måned.</span>
            </div>
        }
        else
        {
            <div class="vp-schedule-table-wrap">
                <table class="table table-sm table-bordered align-middle vp-schedule-table">
                    <thead class="table-light">
                        <tr>
                            <th>Bruger</th>
                            @foreach (var d in MonthDays)
                            {
                                <th>
                                    <div class="schedule-day-num">@d.Day</div>
                                    <div class="schedule-day-name">@d.ToDateTime(new TimeOnly()).ToString("ddd", DanishCulture)</div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in FilteredUsers)
                        {
                            <tr>
                                <td>@u.Name</td>
                                @foreach (var d in MonthDays)
                                {
                                    var w = GetWorkdayFor(u.Id, d);
                                    var color = w != null ? GetStatusColour(w.StatusId) : "transparent";
                                    var tooltip = w != null ? ($"{GetStatusName(w.StatusId)}\n{w.StartTime:hh\\:mm} - {w.EndTime:hh\\:mm}") : string.Empty;
                                    var isWeekend = d.ToDateTime(new TimeOnly()).DayOfWeek == DayOfWeek.Saturday || d.ToDateTime(new TimeOnly()).DayOfWeek == DayOfWeek.Sunday;
                                    string cellBg;
                                    string extraStyle = string.Empty;
                                    if (isWeekend)
                                    {
                                        if (color == "transparent") cellBg = "#f4f4f4"; else { cellBg = color; extraStyle = "filter:grayscale(100%) opacity(0.6);"; }
                                    }
                                    else
                                    {
                                        cellBg = color;
                                    }

                                    var cellStyle = $"text-align:center; background:{cellBg}; {extraStyle}";

                                    <td style="@cellStyle; cursor:@(w != null ? "pointer" : "default")"
                                        @onmouseenter="@( (Microsoft.AspNetCore.Components.Web.MouseEventArgs e) => ShowTooltip(tooltip, e) )"
                                        @onmousemove="@( (Microsoft.AspNetCore.Components.Web.MouseEventArgs e) => MoveTooltip(e) )"
                                        @onmouseleave="HideTooltip"
                                        @onclick="@( () => OnCellClick(w) )">
                                        @if (w != null)
                                        {
                                            <span style="display:block; width:100%; min-height:20px;"></span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}
</div>

<ConfirmDialog
    IsVisible="_showDeleteConfirm"
    Title="Slet arbejdsdag?"
    Message="@_deleteConfirmMessage"
    ConfirmText="Slet arbejdsdag"
    IsProcessing="_isDeleting"
    OnConfirm="ConfirmDeleteEditAsync"
    OnCancel="CancelDeleteEdit" />

@code {
    private List<UserListItemDto>? users;
    private List<WorkDayDto>? workdays;
    private List<StatusDto>? statuses;

    private DateTime DisplayedMonth = DateTime.Today;
    private List<DateOnly> MonthDays = new();
    private bool showOnlyWithAssignments = false;
    private static readonly CultureInfo DanishCulture = CultureInfo.GetCultureInfo("da-DK");
    private string? errorMessage;
    private bool _showDeleteConfirm;
    private bool _isDeleting;
    private string _deleteConfirmMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAllAsync();
            BuildMonthDays();
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
        }
    }

    private async Task LoadAllAsync()
    {
        users = (await UserService.GetAllAsync()).OrderBy(u => u.Name, System.StringComparer.OrdinalIgnoreCase).ToList();
        statuses = (await StatusService.GetAllAsync()).ToList();
        workdays = (await WorkDayService.GetAllAsync()).ToList();
    }

    private void BuildMonthDays()
    {
        var first = new DateTime(DisplayedMonth.Year, DisplayedMonth.Month, 1);
        var daysInMonth = DateTime.DaysInMonth(first.Year, first.Month);
        MonthDays = Enumerable.Range(1, daysInMonth).Select(d => DateOnly.FromDateTime(new DateTime(first.Year, first.Month, d))).ToList();
    }

    private IEnumerable<UserListItemDto> FilteredUsers
    {
        get
        {
            if (users == null) return Enumerable.Empty<UserListItemDto>();
            if (!showOnlyWithAssignments || workdays == null)
            {
                return users.OrderBy(u => u.Name, System.StringComparer.OrdinalIgnoreCase);
            }
            var assignedUserIds = new HashSet<int>(workdays.Where(w => w.Date.Year == DisplayedMonth.Year && w.Date.Month == DisplayedMonth.Month).Select(w => w.UserId));
            return users.Where(u => assignedUserIds.Contains(u.Id)).OrderBy(u => u.Name, System.StringComparer.OrdinalIgnoreCase);
        }
    }

    private WorkDayDto? GetWorkdayFor(int userId, DateOnly date)
    {
        return workdays?.FirstOrDefault(w => w.UserId == userId && w.Date == date);
    }

    private string GetStatusColour(int statusId)
    {
        var s = statuses?.FirstOrDefault(x => x.Id == statusId);
        if (s == null) return "transparent";
        // Ensure the colour string is valid CSS; assume stored as hex or named colour
        return string.IsNullOrWhiteSpace(s.Colour) ? "transparent" : s.Colour;
    }

    private string GetStatusName(int statusId)
    {
        return statuses?.FirstOrDefault(x => x.Id == statusId)?.Name ?? string.Empty;
    }

    private void PrevMonth()
    {
        DisplayedMonth = DisplayedMonth.AddMonths(-1);
        BuildMonthDays();
    }

    private void NextMonth()
    {
        DisplayedMonth = DisplayedMonth.AddMonths(1);
        BuildMonthDays();
    }

    // Tooltip state for custom fast tooltip
    private bool TooltipVisible { get; set; } = false;
    private string TooltipText { get; set; } = string.Empty;
    private double TooltipLeft { get; set; }
    private double TooltipTop { get; set; }

    private void ShowTooltip(string text, Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        TooltipText = text ?? string.Empty;
        TooltipVisible = !string.IsNullOrEmpty(TooltipText);
        TooltipLeft = e.ClientX + 12; // offset from cursor
        TooltipTop = e.ClientY + 12;
        StateHasChanged();
    }

    private void MoveTooltip(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        if (!TooltipVisible) return;
        TooltipLeft = e.ClientX + 12;
        TooltipTop = e.ClientY + 12;
    }

    private void HideTooltip()
    {
        TooltipVisible = false;
        TooltipText = string.Empty;
    }

    // helpers for binding inputs
    private string BindStartTime
    {
        get => EditingWorkday != null ? EditingWorkday.StartTime.ToString("hh\\:mm") : string.Empty;
    }

    private string BindEndTime
    {
        get => EditingWorkday != null ? EditingWorkday.EndTime.ToString("hh\\:mm") : string.Empty;
    }

    private string BindDate
    {
        get => EditingWorkday != null ? EditingWorkday.Date.ToDateTime(new TimeOnly()).ToString("yyyy-MM-dd") : string.Empty;
    }

    private void OnStartTimeInput(ChangeEventArgs e)
    {
        if (EditingWorkday == null) return;
        var val = e?.Value?.ToString();
        if (TimeOnly.TryParse(val, out var t)) EditingWorkday.StartTime = t;
    }

    private void OnEndTimeInput(ChangeEventArgs e)
    {
        if (EditingWorkday == null) return;
        var val = e?.Value?.ToString();
        if (TimeOnly.TryParse(val, out var t)) EditingWorkday.EndTime = t;
    }

    private void OnDateInput(ChangeEventArgs e)
    {
        if (EditingWorkday == null) return;
        var val = e?.Value?.ToString();
        if (DateTime.TryParse(val, out var dt)) EditingWorkday.Date = DateOnly.FromDateTime(dt.Date);
    }

    // Edit modal state
    private bool IsModalOpen { get; set; }
    private WorkDayDto? EditingWorkday { get; set; }

    private void OnCellClick(WorkDayDto? w)
    {
        if (w == null)
        {
            return; // nothing to edit
        }

        // create a shallow copy for editing
        EditingWorkday = new WorkDayDto
        {
            Id = w.Id,
            Date = w.Date,
            StartTime = w.StartTime,
            EndTime = w.EndTime,
            StatusId = w.StatusId,
            UserId = w.UserId
        };
        IsModalOpen = true;
    }

    private async Task SaveEditAsync()
    {
        if (EditingWorkday == null) return;

        var req = new WorkDayRequest
        {
            Date = EditingWorkday.Date,
            StartTime = EditingWorkday.StartTime,
            EndTime = EditingWorkday.EndTime,
            StatusId = EditingWorkday.StatusId,
            UserId = EditingWorkday.UserId
        };

        bool success;
        try
        {
            success = await WorkDayService.UpdateAsync(EditingWorkday.Id, req);
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
            return;
        }
        if (!success)
        {
            errorMessage = "Kunne ikke gemme arbejdsdag.";
            return;
        }

        await LoadAllAsync();
        IsModalOpen = false;
    }

    private void DeleteEditAsync()
    {
        if (EditingWorkday == null) return;
        _deleteConfirmMessage = $"Er du sikker på, at du vil slette arbejdsdagen for {users?.FirstOrDefault(u => u.Id == EditingWorkday.UserId)?.Name ?? "brugeren"} den {EditingWorkday.Date:dd-MM-yyyy}?";
        _showDeleteConfirm = true;
    }

    private void CancelDeleteEdit()
    {
        _showDeleteConfirm = false;
    }

    private async Task ConfirmDeleteEditAsync()
    {
        if (EditingWorkday == null) return;
        _isDeleting = true;
        errorMessage = null;

        try
        {
            var ok = await WorkDayService.DeleteAsync(EditingWorkday.Id);
            if (!ok)
            {
                errorMessage = "Kunne ikke slette arbejdsdag.";
                return;
            }

            await LoadAllAsync();
            IsModalOpen = false;
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
        }
        finally
        {
            _isDeleting = false;
            _showDeleteConfirm = false;
        }
    }

    private bool HandleUnauthorized(Exception ex)
    {
        if (ex is InvalidOperationException invalidOp &&
            invalidOp.Message.Contains("ikke logget ind", StringComparison.OrdinalIgnoreCase))
        {
            AuthState.Clear();
            Navigation.NavigateTo("/login");
            return true;
        }

        if (ex is HttpRequestException httpEx && httpEx.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            AuthState.Clear();
            Navigation.NavigateTo("/login");
            return true;
        }

        errorMessage = "Kunne ikke hente data. Tjek at API'et kører.";
        return false;
    }
}

@if (TooltipVisible)
{
    <div style="position:fixed; left:@(TooltipLeft)px; top:@(TooltipTop)px; background:#222; color:#fff; padding:6px 8px; border-radius:4px; font-size:0.85rem; white-space:pre-line; box-shadow:0 2px 6px rgba(0,0,0,0.3); pointer-events:none; z-index:2000;">
        @TooltipText
    </div>
}

@if (IsModalOpen && EditingWorkday != null)
{
    <div class="modal fade show" style="display:block; background:rgba(0,0,0,0.4);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Rediger arbejdsdag</h5>
                    <button type="button" class="btn-close" @onclick="(() => IsModalOpen = false)"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Bruger</label>
                        <select class="form-select" @bind="EditingWorkday.UserId">
                            @foreach (var u in users ?? Enumerable.Empty<UserListItemDto>())
                            {
                                <option value="@u.Id">@u.Name</option>
                            }
                        </select>
                    </div>

                    <div class="row g-2">
                    <div class="col-md-6 mb-2">
                            <label class="form-label">Start</label>
                            <input class="form-control" type="time" value="@BindStartTime" @oninput="OnStartTimeInput" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Slut</label>
                            <input class="form-control" type="time" value="@BindEndTime" @oninput="OnEndTimeInput" />
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Status</label>
                        <select class="form-select" @bind="EditingWorkday.StatusId">
                            @foreach (var s in statuses ?? Enumerable.Empty<StatusDto>())
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Dato</label>
                        <input class="form-control" type="date" value="@BindDate" @onchange="OnDateInput" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="DeleteEditAsync">Slet</button>
                    <button class="btn btn-primary" @onclick="SaveEditAsync">Gem</button>
                    <button class="btn btn-secondary" @onclick="(() => IsModalOpen = false)">Annuller</button>
                </div>
            </div>
        </div>
    </div>
}

