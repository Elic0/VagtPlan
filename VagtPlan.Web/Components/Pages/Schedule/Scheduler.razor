@page "/scheduler"
@rendermode InteractiveServer
@using VagtPlan.Web.Services
@using VagtPlan.Web.Models
@inject WishService WishService
@inject UserService UserService
@inject StatusService StatusService
@inject WorkDayService WorkDayService
@inject DepartmentApiClient DepartmentApiClient
@inject NavigationManager Navigation
@inject ApiAuthState AuthState

<PageTitle>Planlægger — VagtPlan</PageTitle>

<div class="departments-page">
    <header class="page-header">
        <div>
            <p class="page-eyebrow">Vagtplan</p>
            <h1>Planlægger</h1>
            <p class="page-subtitle">Generer arbejdsdage ud fra ønsker, status og afdeling.</p>
        </div>
    </header>
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert-banner" role="alert">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(infoMessage))
    {
        <div class="vp-alert vp-alert--info" role="status">
            <span class="vp-alert__icon" aria-hidden="true"><i class="bi bi-info-circle"></i></span>
            <div class="vp-alert__content">
                <p class="vp-alert__message">@infoMessage</p>
            </div>
        </div>
    }
    <div class="row g-3 mb-3 vp-split-layout">
        <div class="col-12 col-lg-4">
        <section class="card-panel">
            <h2>Brugere</h2>
            <label class="form-label">Vælg brugere</label>
            <div class="vp-scroll-panel">
                @if (users != null)
                {
                    @foreach (var u in users)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="user_@u.Id" checked="@selectedUserIds.Contains(u.Id)" @onclick="() => ToggleUser(u.Id)" />
                            <label class="form-check-label" for="user_@u.Id">@u.Name</label>
                        </div>
                    }
                }
            </div>
            <div class="mt-3">
                <h6>Antal tildelinger (sidste generering)</h6>
                @if (assignedCounts == null)
                {
                    <div class="text-muted">Ingen tildelinger endnu</div>
                }
                else
                {
                    <div class="vp-record-list vp-record-list-compact">
                        @foreach (var u in users ?? Enumerable.Empty<UserListItemDto>())
                        {
                            var count = assignedCounts.ContainsKey(u.Id) ? assignedCounts[u.Id] : 0;
                            <article class="vp-record-row">
                                <div class="vp-record-main">
                                    <div class="vp-record-title">@u.Name</div>
                                </div>
                                <div class="vp-record-actions">
                                    <span class="count-badge">@count</span>
                                </div>
                            </article>
                        }
                    </div>
                }
            </div>
        </section>
        </div>
        <div class="col-12 col-lg-8">
        <section class="card-panel create-panel">
                <h2>Generer arbejdsdage</h2>
                <div class="row g-2 mb-2">
                    <div class="col-md-6">
                        <label class="form-label">Periode start</label>
                        <DanishDateInput @bind-Value="model.StartDate" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Periode slut</label>
                        <DanishDateInput @bind-Value="model.EndDate" />
                    </div>
                </div>

                <div class="row g-2 mb-2">
                    <div class="col-md-8">
                        <label class="form-label">Afdeling</label>
                        <select class="form-select" @bind="selectedDepartmentId" @bind:event="onchange" @bind:after="OnFiltersChangedAsync">
                            <option value="0">-- vælg afdeling --</option>
                            @if (departments != null)
                            {
                                @foreach (var d in departments)
                                {
                                    <option value="@d.Id">@d.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="filterDept" @bind="filterByDepartment" @bind:event="onchange" @bind:after="OnFiltersChangedAsync" />
                            <label class="form-check-label" for="filterDept">Vis kun brugere i afdelingen</label>
                        </div>
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label">Status (systemstandard)</label>
                    <div class="form-control-plaintext">@DefaultStatusName()</div>
                </div>

                <div>
                    <button type="button" class="btn-primary-action" @onclick="GenerateAsync">Generer</button>
                </div>
        </section>

        <section class="card-panel list-panel">
            <div class="panel-heading">
                <h2>Arbejdsdage i perioden</h2>
                <span class="count-badge">@createdWorkdays.Count</span>
            </div>
            @if (!createdWorkdays.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-calendar2-week"></i></div>
                    <p>Ingen arbejdsdage oprettet endnu</p>
                    <span>Generer arbejdsdage ovenfor.</span>
                </div>
            }
            else
            {
                <div class="department-grid">
                    @foreach (var w in createdWorkdays)
                    {
                        <article class="department-card">
                            <div class="department-card-body">
                                <div class="department-icon"><i class="bi bi-calendar-check"></i></div>
                                <div class="department-card-info">
                                    <h3>@GetUserName(w.UserId)</h3>
                                    <div class="vp-record-meta">
                                        <span class="vp-pill">Dato: @DateDisplayHelper.Format(w.Date)</span>
                                        <span class="vp-pill">Start: @w.StartTime.ToString("HH\\:mm")</span>
                                        <span class="vp-pill">Slut: @w.EndTime.ToString("HH\\:mm")</span>
                                    </div>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    </div>
</div>
</div>

@code {
    private List<UserListItemDto>? users;
    private List<SpecialWishDto>? wishes;
    private List<StatusDto>? statuses;
    private List<DepartmentModel>? departments;

    private int selectedDepartmentId = 0;
    private bool filterByDepartment = false;

    private HashSet<int> selectedUserIds = new();

    private GenerateModel model = new();
    private string? errorMessage;
    private string? infoMessage;

    private List<WorkDayDto> createdWorkdays = [];
    private Dictionary<int, int>? assignedCounts;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadUsers();
            await LoadStatuses();
            await LoadWishes();
            await LoadDepartments();
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
        }
    }
    private async Task LoadUsers()
    {
        var all = (await UserService.GetAllAsync()).OrderBy(u => u.Name, System.StringComparer.OrdinalIgnoreCase).ToList();
        if (filterByDepartment && selectedDepartmentId != 0)
        {
            users = all.Where(u => u.DepartmentId == selectedDepartmentId).ToList();
        }
        else
        {
            users = all;
        }
    }
    private async Task LoadDepartments() => departments = (await DepartmentApiClient.GetAllAsync()).OrderBy(d => d.Name, System.StringComparer.OrdinalIgnoreCase).ToList();

    private async Task OnFiltersChangedAsync()
    {
        await LoadUsers();
        if (users == null) return;

        var visibleUserIds = users.Select(u => u.Id).ToHashSet();
        selectedUserIds.RemoveWhere(id => !visibleUserIds.Contains(id));
    }
    private async Task LoadStatuses() => statuses = (await StatusService.GetAllAsync()).OrderBy(s => s.Name, System.StringComparer.OrdinalIgnoreCase).ToList();
    private async Task LoadWishes() => wishes = (await WishService.GetAllAsync()).ToList();

    private void ToggleUser(int id)
    {
        if (selectedUserIds.Contains(id)) selectedUserIds.Remove(id);
        else selectedUserIds.Add(id);
    }

    private string? GetUserName(int userId) => users?.FirstOrDefault(u => u.Id == userId)?.Name;

    private async Task GenerateAsync()
    {
        errorMessage = null;
        infoMessage = null;
        if (!selectedUserIds.Any())
        {
            errorMessage = "Vælg mindst én bruger.";
            return;
        }

        if (filterByDepartment && selectedDepartmentId == 0)
        {
            errorMessage = "Vælg en afdeling at filtrere efter.";
            return;
        }

        if (!model.StartDate.HasValue || !model.EndDate.HasValue)
        {
            errorMessage = "Vælg start- og slutdato.";
            return;
        }

        if (model.EndDate < model.StartDate)
        {
            errorMessage = "Slutdato skal være efter startdato.";
            return;
        }

        // Determine single system default status
        var defaultStatus = statuses?.FirstOrDefault(s => s.Default);
        if (defaultStatus == null)
        {
            errorMessage = "Ingen systemstandard-status fundet.";
            return;
        }
        var defaultStatusIds = new HashSet<int> { defaultStatus.Id };

        // Build a lookup from dayOfWeek -> list of userIds who have a default-status wish for that day
        var wishesLookup = wishes?
            .Where(w => defaultStatusIds.Contains(w.StatusId))
            .GroupBy(w => w.DayOfWeek)
            .ToDictionary(g => g.Key, g => g.Select(x => x.UserId).Distinct().ToList(), StringComparer.OrdinalIgnoreCase)
            ?? new Dictionary<string, List<int>>(StringComparer.OrdinalIgnoreCase);

        var start = model.StartDate.Value.Date;
        var end = model.EndDate.Value.Date;

        // call server to do generation and balancing; server will avoid duplicates with existing workdays
        var genReq = new GenerateWorkdaysRequest
        {
            StartDate = DateOnly.FromDateTime(start),
            EndDate = DateOnly.FromDateTime(end),
            SelectedUserIds = selectedUserIds.ToList(),
            DepartmentId = selectedDepartmentId
        };

        GenerateWorkdaysResult? genResp;
        try
        {
            genResp = await WorkDayService.GenerateAsync(genReq);
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
            return;
        }
        if (genResp == null)
        {
            errorMessage = "Kunne ikke generere arbejdsdage på serveren.";
            return;
        }

        assignedCounts = genResp.AssignedCounts;

        var periodStart = DateOnly.FromDateTime(start);
        var periodEnd = DateOnly.FromDateTime(end);

        try
        {
            await LoadWorkdaysInPeriodAsync(periodStart, periodEnd);
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
            return;
        }

        var newlyCreated = genResp.Created.Count;
        if (newlyCreated > 0)
        {
            infoMessage = $"{newlyCreated} nye arbejdsdage blev oprettet.";
        }
        else if (createdWorkdays.Any())
        {
            infoMessage = "Ingen nye arbejdsdage blev oprettet — datoerne i perioden var allerede tildelt. Listen viser eksisterende arbejdsdage.";
        }
    }

    private async Task LoadWorkdaysInPeriodAsync(DateOnly start, DateOnly end)
    {
        var all = await WorkDayService.GetAllAsync();
        createdWorkdays = all
            .Where(w => w.Date >= start && w.Date <= end && selectedUserIds.Contains(w.UserId))
            .OrderBy(w => w.Date)
            .ThenBy(w => w.UserId)
            .ToList();
    }

    private class GenerateModel
    {
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
    }

    private string DefaultStatusName()
    {
        var s = statuses?.FirstOrDefault(x => x.Default);
        return s != null ? s.Name : "(ingen systemstandard-status)";
    }

    private bool HandleUnauthorized(Exception ex)
    {
        if (ex is InvalidOperationException invalidOp &&
            invalidOp.Message.Contains("ikke logget ind", StringComparison.OrdinalIgnoreCase))
        {
            AuthState.Clear();
            Navigation.NavigateTo("/login");
            return true;
        }

        if (ex is HttpRequestException httpEx && httpEx.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            AuthState.Clear();
            Navigation.NavigateTo("/login");
            return true;
        }

        errorMessage = "Kunne ikke hente data. Tjek at API'et kører.";
        return false;
    }
}
