@page "/Error"
@using System.Diagnostics

<PageTitle>Fejl — VagtPlan</PageTitle>

<div class="departments-page">
    <header class="page-header">
        <div>
            <p class="page-eyebrow">System</p>
            <h1>Der opstod en fejl</h1>
            <p class="page-subtitle">Noget gik galt. Prøv igen, eller genindlæs siden.</p>
        </div>
    </header>

    <div class="vp-alert vp-alert--error" role="alert">
        <div class="vp-alert__icon" aria-hidden="true">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <div class="vp-alert__content">
            <p class="vp-alert__title">Uventet fejl</p>
            <p class="vp-alert__message">Hvis problemet bliver ved, så log ud og ind igen, eller kontakt en administrator.</p>
        </div>
    </div>

@if (ShowRequestId)
{
    <section class="card-panel">
        <h2>Fejl-id</h2>
        <p><strong>Request ID:</strong> <code>@requestId</code></p>
    </section>
}
</div>

@code{
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private string? requestId;
    private bool ShowRequestId => !string.IsNullOrEmpty(requestId);

    protected override void OnInitialized()
    {
        requestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
