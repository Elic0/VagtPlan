@page "/statuses"
@rendermode InteractiveServer
@using VagtPlan.Web.Services
@inject StatusService StatusService
@inject NavigationManager Navigation
@inject ApiAuthState AuthState

<PageTitle>Statusser — VagtPlan</PageTitle>

<div class="departments-page">
    <header class="page-header">
        <div>
            <p class="page-eyebrow">Vagtplan</p>
            <h1>Statusser</h1>
            <p class="page-subtitle">Administrer statusser, farver og standardstatus.</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert-banner" role="alert">@errorMessage</div>
    }

    <section class="card-panel create-panel">
        <h2>Opret status</h2>
        <button type="button" class="@(showCreate ? "btn-secondary" : "btn-primary-action") create-action-toggle" @onclick="() => showCreate = !showCreate">
            @((showCreate) ? "Annuller" : "Ny status")
        </button>

        @if (showCreate)
        {
            <div>
                <div class="mb-2">
                    <label class="form-label">Navn</label>
                    <input class="form-control" @bind="newStatus.Name" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Farve</label>
                    <div class="input-group" style="max-width:360px;">
                        <input type="color" class="form-control form-control-color" style="width:48px; padding:0;" @bind="newStatus.Colour" />
                        <input class="form-control" @bind="newStatus.Colour" @bind:event="oninput" />
                    </div>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="availableCreate" @bind="newStatus.IsAvailable" />
                    <label class="form-check-label" for="availableCreate">Tilgængelig</label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="defaultCreate" @bind="newStatus.Default" />
                    <label class="form-check-label" for="defaultCreate">Standard</label>
                </div>
                <button class="btn-primary-action" @onclick="CreateStatusAsync">Opret</button>
            </div>
        }
    </section>

    @if (editingStatus != null)
    {
        <section class="card-panel create-panel">
            <h2>Rediger status (@editingStatus.Name)</h2>
            <div class="mb-2">
                <label class="form-label">Navn</label>
                <input class="form-control" @bind="editModel.Name" />
            </div>
            <div class="mb-2">
                <label class="form-label">Farve</label>
                <div class="input-group" style="max-width:360px;">
                    <input type="color" class="form-control form-control-color" style="width:48px; padding:0;" @bind="editModel.Colour" />
                    <input class="form-control" @bind="editModel.Colour" @bind:event="oninput" />
                </div>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="availableEdit" @bind="editModel.IsAvailable" />
                <label class="form-check-label" for="availableEdit">Tilgængelig</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="defaultEdit" @bind="editModel.Default" />
                <label class="form-check-label" for="defaultEdit">Standard</label>
            </div>
            <div class="vp-row-actions">
                <button class="btn-primary-action" @onclick="UpdateStatusAsync">Gem</button>
                <button class="btn-secondary" @onclick="() => editingStatus = null">Annuller</button>
            </div>
        </section>
    }

    <section class="card-panel list-panel">
        <div class="panel-heading">
            <h2>Alle statusser</h2>
            <span class="count-badge">@(statuses?.Count ?? 0)</span>
        </div>
        @if (statuses == null)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <span>Indlæser statusser…</span>
            </div>
        }
        else if (!statuses.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-palette2"></i></div>
                <p>Ingen statusser fundet</p>
                <span>Opret din første status ovenfor.</span>
            </div>
        }
        else
        {
            <div class="department-grid">
                @foreach (var s in statuses)
                {
                    <article class="department-card">
                        <div class="department-card-body">
                            <div class="department-icon department-icon--color" style="--status-color:@s.Colour"></div>
                            <div class="department-card-info">
                                <h3>@s.Name</h3>
                                <div class="vp-record-meta">
                                    <span class="vp-color-chip" style="--chip-color:@s.Colour">@s.Colour</span>
                                    <span class="vp-pill">Tilgængelig: @(s.IsAvailable ? "Ja" : "Nej")</span>
                                    <span class="vp-pill">Standard: @(s.Default ? "Ja" : "Nej")</span>
                                </div>
                            </div>
                        </div>
                        <div class="department-card-actions">
                            <button class="btn-edit" @onclick="() => StartEdit(s)">
                                <i class="bi bi-pencil"></i>
                                Rediger
                            </button>
                            <button class="btn-delete" @onclick="() => DeleteStatusAsync(s)">
                                <i class="bi bi-trash3"></i>
                                Slet
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

<ConfirmDialog
    IsVisible="_showDeleteConfirm"
    Title="Slet status?"
    Message="@_deleteConfirmMessage"
    ConfirmText="Slet status"
    IsProcessing="_isDeleting"
    OnConfirm="ConfirmDeleteStatusAsync"
    OnCancel="CancelDeleteStatus" />

@code {
    private List<StatusDto>? statuses;
    private bool showCreate;
    private string? errorMessage;

    private StatusRequest newStatus = new StatusRequest { Colour = "#ffffff" };

    private StatusDto? editingStatus;
    private StatusRequest editModel = new StatusRequest { Colour = "#ffffff" };
    private StatusDto? _pendingDeleteStatus;
    private bool _showDeleteConfirm;
    private bool _isDeleting;
    private string _deleteConfirmMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadStatuses();
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
        }
    }

    private async Task LoadStatuses()
    {
        statuses = (await StatusService.GetAllAsync()).OrderBy(s => s.Name, System.StringComparer.OrdinalIgnoreCase).ToList();
    }

    private async Task CreateStatusAsync()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(newStatus.Name))
        {
            errorMessage = "Navn må ikke være tomt.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newStatus.Colour)) newStatus.Colour = "#ffffff";
        // ensure leading #
        if (!newStatus.Colour.StartsWith("#")) newStatus.Colour = "#" + newStatus.Colour;

        try
        {
            var created = await StatusService.CreateAsync(newStatus);
            if (created != null)
            {
                newStatus = new StatusRequest { Colour = "#ffffff" };
                showCreate = false;
                await LoadStatuses();
            }
            else
            {
                errorMessage = "Kunne ikke oprette status.";
            }
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
        }
    }

    private void StartEdit(StatusDto s)
    {
        editingStatus = s;
        editModel = new StatusRequest
        {
            Name = s.Name,
            Colour = string.IsNullOrWhiteSpace(s.Colour) ? "#ffffff" : s.Colour,
            IsAvailable = s.IsAvailable,
            Default = s.Default
        };
    }

    private async Task UpdateStatusAsync()
    {
        if (editingStatus == null) return;
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(editModel.Name))
        {
            errorMessage = "Navn må ikke være tomt.";
            return;
        }

        if (string.IsNullOrWhiteSpace(editModel.Colour)) editModel.Colour = "#ffffff";
        if (!editModel.Colour.StartsWith("#")) editModel.Colour = "#" + editModel.Colour;

        try
        {
            var ok = await StatusService.UpdateAsync(editingStatus.Id, editModel);
            if (ok)
            {
                editingStatus = null;
                await LoadStatuses();
            }
            else
            {
                errorMessage = "Kunne ikke gemme status.";
            }
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
        }
    }

    private void DeleteStatusAsync(StatusDto s)
    {
        _pendingDeleteStatus = s;
        _deleteConfirmMessage = $"Er du sikker på, at du vil slette status '{s.Name}'? Denne handling kan ikke fortrydes.";
        _showDeleteConfirm = true;
    }

    private void CancelDeleteStatus()
    {
        _showDeleteConfirm = false;
        _pendingDeleteStatus = null;
    }

    private async Task ConfirmDeleteStatusAsync()
    {
        if (_pendingDeleteStatus == null) return;

        _isDeleting = true;
        errorMessage = null;

        try
        {
            var ok = await StatusService.DeleteAsync(_pendingDeleteStatus.Id);
            if (ok) await LoadStatuses();
            else errorMessage = "Kunne ikke slette status.";
        }
        catch (Exception ex) when (HandleUnauthorized(ex))
        {
        }
        finally
        {
            _isDeleting = false;
            _showDeleteConfirm = false;
            _pendingDeleteStatus = null;
        }        
    }

    private bool HandleUnauthorized(Exception ex)
    {
        if (ex is InvalidOperationException invalidOp &&
            invalidOp.Message.Contains("ikke logget ind", StringComparison.OrdinalIgnoreCase))
        {
            AuthState.Clear();
            Navigation.NavigateTo("/login");
            return true;
        }

        if (ex is HttpRequestException httpEx && httpEx.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            AuthState.Clear();
            Navigation.NavigateTo("/login");
            return true;
        }

        return false;
    }
}