@page "/counter"
@rendermode InteractiveServer

<PageTitle>Tæller — VagtPlan</PageTitle>

<div class="departments-page">
    <header class="page-header">
        <div>
            <p class="page-eyebrow">Demo</p>
            <h1>Tæller</h1>
            <p class="page-subtitle">En lille test-side (kan fjernes senere).</p>
        </div>
    </header>

    <section class="card-panel">
        <h2>Status</h2>
        <p role="status">Nuværende værdi: <strong>@currentCount</strong></p>

        <div class="form-actions" style="justify-content:flex-start;">
            <button class="vp-btn vp-btn--primary" @onclick="IncrementCount">
                <span class="vp-btn__icon" aria-hidden="true"><i class="bi bi-plus-lg"></i></span>
                Forøg
            </button>
        </div>
    </section>
</div>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
