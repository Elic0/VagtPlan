@page "/weather"
@attribute [StreamRendering(true)]
@attribute [OutputCache(Duration = 5)]

@inject WeatherApiClient WeatherApi

<PageTitle>Vejr — VagtPlan</PageTitle>

<div class="departments-page">
    <header class="page-header">
        <div>
            <p class="page-eyebrow">Demo</p>
            <h1>Vejr</h1>
            <p class="page-subtitle">Viser eksempeldata hentet fra API.</p>
        </div>
    </header>

@if (forecasts == null)
{
    <div class="loading-state">
        <div class="spinner"></div>
        <span>Henter vejrdata…</span>
    </div>
}
else
{
    <section class="card-panel list-panel">
        <div class="panel-heading">
            <h2>Prognose</h2>
            <span class="count-badge">@forecasts.Length</span>
        </div>
        <div style="overflow:auto; max-width:100%;">
            <table class="table table-sm table-bordered align-middle" style="white-space:nowrap;">
                <thead class="table-light">
                    <tr>
                        <th>Dato</th>
                        <th aria-label="Temperatur i Celsius">Temp. (°C)</th>
                        <th aria-label="Temperatur i Fahrenheit">Temp. (°F)</th>
                        <th>Opsummering</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var forecast in forecasts)
                    {
                        <tr>
                            <td>@forecast.Date.ToShortDateString()</td>
                            <td>@forecast.TemperatureC</td>
                            <td>@forecast.TemperatureF</td>
                            <td>@forecast.Summary</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}
</div>

@code {
    private WeatherForecast[]? forecasts;

    protected override async Task OnInitializedAsync()
    {
        forecasts = await WeatherApi.GetWeatherAsync();
    }
}
