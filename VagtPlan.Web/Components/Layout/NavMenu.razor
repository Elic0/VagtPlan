@rendermode InteractiveServer
@implements IDisposable
@inject ApiAuthState AuthState
@inject NavigationManager Navigation

<header class="vp-header">
    <div class="vp-header-surface" aria-hidden="true"></div>

    <div class="vp-header-container">
        <div class="vp-header-row">
            <a href="/" class="vp-brand" @onclick="CloseMenu">
                <span class="vp-brand-icon" aria-hidden="true">
                    <i class="bi bi-telephone-fill"></i>
                </span>
                <span class="vp-brand-text">
                    <span class="vp-brand-title">NSC-TelefonVagt</span>
                    <span class="vp-brand-sub">Vagtplanlægning</span>
                </span>
            </a>

            <button type="button"
                    class="vp-menu-btn @(_menuOpen ? "is-open" : "")"
                    @onclick="ToggleMenu"
                    aria-label="@(_menuOpen ? "Luk menu" : "Åbn menu")"
                    aria-expanded="@_menuOpen"
                    aria-controls="vp-main-nav">
                <span class="vp-menu-btn-bar"></span>
                <span class="vp-menu-btn-bar"></span>
                <span class="vp-menu-btn-bar"></span>
            </button>

            <div id="vp-main-nav" class="vp-nav-drawer @(_menuOpen ? "is-open" : "")">
                <nav class="vp-nav" aria-label="Hovednavigation">
                    <NavLink href="" Match="NavLinkMatch.All" class="vp-nav-item" ActiveClass="is-active" @onclick="CloseMenu">
                        <i class="bi bi-house-door" aria-hidden="true"></i>
                        <span>Forside</span>
                    </NavLink>
                    <NavLink href="departments" class="vp-nav-item" ActiveClass="is-active" @onclick="CloseMenu">
                        <i class="bi bi-building" aria-hidden="true"></i>
                        <span>Afdelinger</span>
                    </NavLink>
                    <NavLink href="statuses" class="vp-nav-item" ActiveClass="is-active" @onclick="CloseMenu">
                        <i class="bi bi-palette2" aria-hidden="true"></i>
                        <span>Statusser</span>
                    </NavLink>
                    <NavLink href="specialwishes" class="vp-nav-item" ActiveClass="is-active" @onclick="CloseMenu">
                        <i class="bi bi-stars" aria-hidden="true"></i>
                        <span>Særlige ønsker</span>
                    </NavLink>
                    <NavLink href="scheduler" class="vp-nav-item" ActiveClass="is-active" @onclick="CloseMenu">
                        <i class="bi bi-calendar2-week" aria-hidden="true"></i>
                        <span>Planlægger</span>
                    </NavLink>
                    <NavLink href="schedule" class="vp-nav-item" ActiveClass="is-active" @onclick="CloseMenu">
                        <i class="bi bi-calendar3" aria-hidden="true"></i>
                        <span>Vagtplan</span>
                    </NavLink>
                    <NavLink href="users" class="vp-nav-item" ActiveClass="is-active" @onclick="CloseMenu">
                        <i class="bi bi-building" aria-hidden="true"></i>
                        <span>Users</span>
                    </NavLink>
                    <NavLink href="role" class="vp-nav-item" ActiveClass="is-active" @onclick="CloseMenu">
                        <i class="bi bi-building" aria-hidden="true"></i>
                        <span>Roles</span>
                    </NavLink>
                    @if (AuthState.IsAuthenticated)
                    {
                        <button type="button" class="vp-nav-item vp-nav-logout" @onclick="Logout" aria-label="Log ud">
                            <span class="vp-nav-logout-icon" aria-hidden="true">
                                <i class="bi bi-box-arrow-right"></i>
                            </span>
                            <span>Log ud</span>
                        </button>
                    }
                </nav>
            </div>
        </div>
    </div>

    @if (_menuOpen)
    {
        <button type="button" class="vp-nav-backdrop" @onclick="CloseMenu" aria-label="Luk menu"></button>
    }
</header>

@code {
    private bool _menuOpen;

    protected override void OnInitialized()
    {
        AuthState.Changed += HandleAuthStateChanged;
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;

    private void Logout()
    {
        AuthState.Clear();
        CloseMenu();
        Navigation.NavigateTo("/login");
    }

    private void HandleAuthStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthState.Changed -= HandleAuthStateChanged;
    }
}

