@inherits LayoutComponentBase
@implements IDisposable
@rendermode InteractiveServer
@inject VagtPlan.Web.Services.ApiAuthState AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="app-shell">
    @if (ShouldRenderProtectedContent)
    {
        <NavMenu />
    }

    <main class="app-main">
        <div class="app-content">
            @if (ShouldRenderProtectedContent)
            {
                @Body
            }
            else if (_authReady && IsLoginPage)
            {
                @Body
            }
            else
            {
                <div class="loading-state" aria-live="polite">
                    <span class="spinner" aria-hidden="true"></span>
                    <span>Indlæser...</span>
                </div>
            }
        </div>
    </main>
</div>

<div id="blazor-error-ui">
    Der opstod en uventet fejl.
    <a href="" class="reload">Genindlæs</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _authReady;
    private bool IsLoginPage => Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/').ToLowerInvariant() == "login";
    private bool ShouldRenderProtectedContent => _authReady && AuthState.IsAuthenticated;

    protected override void OnInitialized()
    {
        AuthState.Changed += HandleAuthChanged;
    }

    private void HandleAuthChanged()
    {
        _ = InvokeAsync(() =>
        {
            if (_authReady)
            {
                EnforceLogin();
            }

            StateHasChanged();
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _authReady)
        {
            return;
        }

        await AuthState.InitializeAsync(JS);
        _authReady = true;
        EnforceLogin();
        StateHasChanged();
    }

    private void EnforceLogin()
    {
        var isLoginPage = IsLoginPage;

        if (!AuthState.IsAuthenticated && !isLoginPage)
        {
            Navigation.NavigateTo("/login", replace: true);
        }
        else if (AuthState.IsAuthenticated && isLoginPage)
        {
            Navigation.NavigateTo("/", replace: true);
        }
    }

    public void Dispose()
    {
        AuthState.Changed -= HandleAuthChanged;
    }
}
